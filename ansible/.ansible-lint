profile: null
warn_list:
  - role-name
# ansible-lint cannot resolve {{ playbook_dir }} in dynamic include_tasks paths.
# These virtual paths don't exist on disk — they resolve correctly at runtime.
exclude_paths:
  - roles/arr_suite/tasks/tasks/
  - roles/grafana/tasks/tasks/
  - roles/jellyfin/tasks/tasks/
  - roles/jellyseerr/tasks/tasks/
  - roles/maintainerr/tasks/tasks/
  - roles/n8n/tasks/tasks/
  - roles/paperless-ngx/tasks/tasks/
  - roles/plex/tasks/tasks/
  - roles/tracearr/tasks/tasks/
