global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
  - job_name: 'loki'
    static_configs:
      - targets: ['loki:3100']
  - job_name: 'cadvisor'
    static_configs:
{% for host in groups.get('docker_vm_hosts', []) %}
{% if host == inventory_hostname %}
      - targets:
        - {{ ansible_default_ipv4.address }}:8089
        labels:
          instance: {{ host }}.{{ internal_domain }}:8089
{% else %}
      - targets:
        - {{ host }}.{{ internal_domain }}:8089
{% endif %}
{% endfor %}
