services:
  grafana:
    image: grafana/grafana-oss:{{ grafana_version }}
    container_name: grafana
    restart: unless-stopped
    user: "{{ docker_user_puid }}"
    environment:
     - GF_SERVER_ROOT_URL={{ internal_grafana_url }}
     - GF_INSTALL_PLUGINS={{ grafana_plugins }}
    ports:
     - '{{ grafana_port }}:3000'
    volumes:
     - {{ grafana_folder }}:/var/lib/grafana
     - {{ grafana_folder }}/provisioning:/etc/grafana/provisioning
    networks:
      - grafana_net
    depends_on:
      - loki
      - prometheus
      - influxdb

  loki:
    image: grafana/loki:{{ grafana_loki_version }}
    container_name: loki
    restart: unless-stopped
    user: "{{ docker_user_puid }}:{{ docker_user_pgid }}"
    command: -config.file=/etc/loki/local-config.yaml
    ports:
    - '{{ grafana_loki_port }}:3100'
    volumes:
      - {{ grafana_loki_data_folder }}:/loki
    networks:
      - grafana_net

  prometheus:
    image: prom/prometheus:{{ grafana_prometheus_version }}
    container_name: prometheus
    restart: unless-stopped
    user: "{{ docker_user_puid }}:{{ docker_user_pgid }}"
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.enable-remote-write-receiver'
    ports:
      - '{{ grafana_prometheus_port }}:9090'
    volumes:
      - {{ grafana_prometheus_data_folder }}:/prometheus
      - {{ grafana_prometheus_data_folder }}/prometheus.yml:/etc/prometheus/prometheus.yml
    networks:
      - grafana_net

  influxdb:
    image: influxdb:{{ grafana_influxdb_version }}
    container_name: influxdb
    restart: unless-stopped
    environment:
      - DOCKER_INFLUXDB_INIT_MODE=setup
      - DOCKER_INFLUXDB_INIT_USERNAME={{ grafana_influxdb_admin_user }}
      - DOCKER_INFLUXDB_INIT_PASSWORD={{ grafana_influxdb_admin_password }}
      - DOCKER_INFLUXDB_INIT_ORG={{ grafana_influxdb_org }}
      - DOCKER_INFLUXDB_INIT_BUCKET={{ grafana_influxdb_bucket }}
      - DOCKER_INFLUXDB_INIT_ADMIN_TOKEN={{ grafana_influxdb_admin_token }}
    ports:
      - '{{ grafana_influxdb_port }}:8086'
    volumes:
      - {{ grafana_influxdb_data_folder }}/data:/var/lib/influxdb2
      - {{ grafana_influxdb_data_folder }}/config:/etc/influxdb2
    networks:
      - grafana_net

  snmp-exporter:
    image: prom/snmp-exporter:{{ grafana_snmp_exporter_version }}
    container_name: snmp-exporter
    restart: unless-stopped
    ports:
      - '{{ grafana_snmp_exporter_port }}:9116'
    volumes:
      - {{ grafana_snmp_exporter_data_folder }}/snmp.yml:/etc/snmp_exporter/snmp.yml:ro
    networks:
      - grafana_net

networks:
  grafana_net:
    driver: bridge
