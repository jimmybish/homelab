apiVersion: 1

providers:
  - name: 'Homelab Dashboards'
    orgId: 1
    type: file
    # Dashboards are managed as code in this repo. Disable UI edits/deletes so
    # the file-provisioned copies are the single source of truth.
    disableDeletion: true
    allowUiUpdates: false
    updateIntervalSeconds: 30
    options:
      # Path inside the container; the host provisioning dir is bind-mounted to
      # /etc/grafana/provisioning. JSON files live in the json/ subfolder so the
      # provider never tries to parse this provider yaml as a dashboard.
      path: /etc/grafana/provisioning/dashboards/json
      foldersFromFilesStructure: false
