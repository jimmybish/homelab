apiVersion: 1

groups:
  # Host Down - fires when any scrape target is unreachable
  - orgId: 1
    name: host_down
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: host-down-1
        title: Host Down
        condition: C
        for: 2m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "Host {% raw %}{{ $labels.instance }}{% endraw %} is down"
          description: "The target {% raw %}{{ $labels.instance }}{% endraw %} (job: {% raw %}{{ $labels.job }}{% endraw %}) has been unreachable for more than 2 minutes."
        labels:
          severity: critical
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "up == 0"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 0.5

  # Container Down - fires when a container stops reporting metrics
  - orgId: 1
    name: container_down
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: container-down-1
        title: Container Down
        condition: C
        for: 2m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "Container {% raw %}{{ $labels.name }}{% endraw %} is not running on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "The Docker container {% raw %}{{ $labels.name }}{% endraw %} on {% raw %}{{ $labels.instance }}{% endraw %} has been down for more than 2 minutes."
        labels:
          severity: critical
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "time() - container_last_seen{name!=\"\"}"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 60

  # Disk Space Low (local) - fires when a local filesystem (zfs/ext4/xfs/btrfs/...) drops below threshold
  - orgId: 1
    name: disk_space_low_local
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: disk-space-low-local-1
        title: Disk Space Low (Local)
        condition: C
        for: 5m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "Disk space low on {% raw %}{{ $labels.instance }}{% endraw %} ({% raw %}{{ $labels.mountpoint }}{% endraw %})"
          description: "Filesystem {% raw %}{{ $labels.mountpoint }}{% endraw %} on {% raw %}{{ $labels.instance }}{% endraw %} has less than {{ grafana_alert_disk_threshold_local }}% free space."
        labels:
          severity: warning
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "(node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|nfs|nfs4|fuse.*|cifs|smbfs|autofs|devtmpfs|ramfs\",mountpoint!~\"/boot.*\"} / node_filesystem_size_bytes) * 100"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: lt
                    params:
                      - {{ grafana_alert_disk_threshold_local }}

  # Disk Space Low (QNAP) - fires when a QNAP SNMP volume drops below threshold
  - orgId: 1
    name: disk_space_low_qnap
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: disk-space-low-qnap-1
        title: Disk Space Low (QNAP)
        condition: C
        for: 5m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "QNAP volume low on {% raw %}{{ $labels.instance }}{% endraw %} (volume index {% raw %}{{ $labels.sysVolumeIndexEX }}{% endraw %})"
          description: "QNAP volume index {% raw %}{{ $labels.sysVolumeIndexEX }}{% endraw %} on {% raw %}{{ $labels.instance }}{% endraw %} has less than {{ grafana_alert_disk_threshold_qnap }}% free space."
        labels:
          severity: warning
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "(sysVolumeFreeSizeEX / sysVolumeTotalSizeEX) * 100"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: lt
                    params:
                      - {{ grafana_alert_disk_threshold_qnap }}

  # QNAP Health - fires on high temperature, fan failure, or volume degradation
  - orgId: 1
    name: qnap_health
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: qnap-temp-high-1
        title: QNAP Temperature High
        condition: C
        for: 2m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "QNAP system temperature is above {{ grafana_alert_qnap_temp_threshold }}C on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "QNAP NAS {% raw %}{{ $labels.instance }}{% endraw %} system temperature has exceeded {{ grafana_alert_qnap_temp_threshold }}C for more than 2 minutes."
        labels:
          severity: critical
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "systemTemperature"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - {{ grafana_alert_qnap_temp_threshold }}

      - uid: qnap-fan-fail-1
        title: QNAP Fan Failure
        condition: C
        for: 2m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "QNAP fan stopped on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "A fan on QNAP NAS {% raw %}{{ $labels.instance }}{% endraw %} is reporting 0 RPM. This may indicate a hardware failure."
        labels:
          severity: critical
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "sysFanSpeed"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: lt
                    params:
                      - 1

      - uid: qnap-volume-degrade-1
        title: QNAP Volume Degraded
        condition: C
        for: 5m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "QNAP volume degraded on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "A RAID volume on QNAP NAS {% raw %}{{ $labels.instance }}{% endraw %} is in a degraded state. Immediate attention required."
        labels:
          severity: critical
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              # snmp_exporter exposes QNAP raidStatus as numeric=1 always; the actual
              # status is encoded in a same-named label as hex-ASCII. Healthy = "Ready"
              # (0x5265616479). Alert only when label is NOT Ready. When healthy the
              # series doesn't exist -> reduce returns NoData -> noDataState=OK resolves.
              expr: "raidStatus{raidStatus!=\"0x5265616479\"}"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 0

  # SNMP Data Stale - fires when QNAP SNMP scrapes have been failing for too long
  - orgId: 1
    name: snmp_data_stale
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: snmp-data-stale-1
        title: SNMP Data Stale
        condition: C
        for: {{ grafana_alert_snmp_stale_minutes }}m
        noDataState: "Alerting"
        execErrState: "OK"
        annotations:
          summary: "No SNMP data from {% raw %}{{ $labels.instance }}{% endraw %} for {{ grafana_alert_snmp_stale_minutes }}+ minutes"
          description: "The SNMP scrape target {% raw %}{{ $labels.instance }}{% endraw %} (job: {% raw %}{{ $labels.job }}{% endraw %}) has been unreachable for more than {{ grafana_alert_snmp_stale_minutes }} minutes. The SNMP service on the device may need to be restarted."
        labels:
          severity: warning
        data:
          - refId: A
            relativeTimeRange:
              from: 900
              to: 0
            datasourceUid: {{ grafana_prometheus_uid }}
            model:
              refId: A
              expr: "up{job=~\"snmp_qnap.*\"} == 0"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 0.5

  # Loki Error Patterns - fires when error log rate spikes
  - orgId: 1
    name: loki_error_patterns
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: loki-errors-1
        title: High Error Rate in Logs
        condition: C
        for: 5m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "High error rate detected in logs for {% raw %}{{ $labels.host }}{% endraw %} / {% raw %}{{ $labels.container_name }}{% endraw %}"
          description: "More than {{ grafana_alert_loki_error_threshold }} error/fatal/panic log lines detected in 5 minutes from {% raw %}{{ $labels.host }}{% endraw %} ({% raw %}{{ $labels.container_name }}{% endraw %})."
        labels:
          severity: warning
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: {{ grafana_loki_uid }}
            model:
              refId: A
              # Parse logfmt and filter on level=error|fatal|panic instead of raw regex.
              # Also drop self-feedback / known-noise lines:
              #   - Loki internals (caller=scheduler_processor.go / retry.go / metrics.go / engine.go / ingester.go)
              #   - Grafana noisy loggers (ngalert.*, provisioning.*, infra.usagestats.*)
              #   - "context canceled" tails of the above
              # See `.github/agents/grafana_admin.agent.md` for the self-feedback caveat.
              expr: "sum by (host, container_name) (count_over_time({source=\"docker\"} != \"caller=scheduler_processor.go\" != \"caller=retry.go\" != \"caller=metrics.go\" != \"caller=engine.go\" != \"caller=ingester.go\" != \"App runner exited without error\" !~ \"logger=(ngalert|provisioning|infra\\\\.usagestats)\" | logfmt | level=~\"(?i)error|fatal|panic\" != \"context canceled\" [5m]))"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - {{ grafana_alert_loki_error_threshold }}

  # N8N Discord Trigger Loop - fires when the Discord bot trigger nodes are cycling
  # through repeated disconnect/reconnect loops, indicating stale IPC state
  - orgId: 1
    name: n8n_discord_trigger_loop
    folder: Infrastructure
    interval: 1m
    rules:
      - uid: n8n-discord-trigger-loop-1
        title: N8N Discord Trigger Reconnect Loop
        condition: C
        for: 5m
        noDataState: "OK"
        execErrState: "OK"
        annotations:
          summary: "N8N Discord trigger nodes are in a reconnect loop on {% raw %}{{ $labels.host }}{% endraw %}"
          description: "More than {{ grafana_alert_n8n_trigger_loop_threshold }} 'removing trigger node' events detected in 5 minutes from the N8N container on {% raw %}{{ $labels.host }}{% endraw %}. This indicates the Discord bot IPC connection is cycling and workflows may not be firing."
        labels:
          severity: warning
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: {{ grafana_loki_uid }}
            model:
              refId: A
              expr: "sum by (host) (count_over_time({container_name=\"n8n\"} |= \"removing trigger node\" [5m]))"
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              intervalMs: 1000
              maxDataPoints: 43200
              settings:
                mode: ""
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - {{ grafana_alert_n8n_trigger_loop_threshold }}
