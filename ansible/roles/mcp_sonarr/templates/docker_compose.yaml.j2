services:
  mcp-sonarr:
    build:
      context: "{{ mcp_sonarr_folder }}/build"
      dockerfile: Dockerfile
    image: mcp-sonarr:{{ mcp_sonarr_version }}
    container_name: mcp-sonarr
    restart: unless-stopped
    environment:
      - SONARR_API_KEY={{ sonarr_api_key }}
      - SONARR_BASE_URL={{ mcp_sonarr_api_base_url }}
    network_mode: host
