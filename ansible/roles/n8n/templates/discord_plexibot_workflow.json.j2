        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ '{{' }} JSON.stringify({name: 'plexibot-' + $json.sessionId, auto_archive_duration: 1440}) {{ '}}' }}",
        "options": {}
      },
